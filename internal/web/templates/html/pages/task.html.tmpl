{{- /* Task detail page. Full-bleed port of the peek-sheet sections
     (prototype/peek.html): header + status, Labels, Parent, Blocked-by,
     Blocks, Description, Completion note, History. No close button,
     no "Open full page" CTA — this IS the full page. */ -}}
{{define "title"}}{{.ShortID}} {{.Title}} · Jobs{{end}}
{{define "content"}}
<section class="c-section" aria-labelledby="task-title">
  <header class="c-section__header">
    <div class="stack stack-gap-xs" style="min-width: 0; flex: 1">
      <div class="row row-gap-sm">
        <span class="c-id-pill">{{.ShortID}}</span>
        {{template "status-pill" .Status}}
        {{if .ClaimedBy}}
        <span class="t-muted t-body-sm">claimed by
          <a href="/actors/{{.ClaimedBy}}" class="c-log-row__actor" data-actor="{{.ClaimedBy}}">
            <span class="c-avatar c-avatar-sm" data-actor="{{.ClaimedBy}}"></span>
            <span>{{.ClaimedBy}}</span>
          </a>
        </span>
        {{end}}
      </div>
      <h1 id="task-title">{{.Title}}</h1>
    </div>
    <button class="c-bell" data-task-bell="{{.ShortID}}" aria-label="Notify when this task is done" aria-pressed="false" title="Browser notification on completion">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M3.5 11.5h9l-1-1.5V7a3.5 3.5 0 0 0-7 0v3l-1 1.5z" stroke-linejoin="round" />
        <path d="M6.5 13a1.5 1.5 0 0 0 3 0" stroke-linecap="round" />
      </svg>
    </button>
  </header>
</section>

{{if .Labels}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Labels</h2>
  <div class="row row-gap-xs" style="flex-wrap: wrap">
    {{range .Labels}}<a href="{{.URL}}" class="c-label-pill" data-label="{{.Name}}">{{.Name}}</a>{{end}}
  </div>
</section>
{{end}}

{{if .Parent}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Parent</h2>
  <div class="row row-gap-sm">
    <a href="{{.Parent.URL}}" class="c-id-pill">{{.Parent.ShortID}}</a>
    <span class="t-body-sm">{{.Parent.Title}}</span>
  </div>
</section>
{{end}}

{{if .BlockedBy}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Blocked by</h2>
  <div class="stack stack-gap-xs">
    {{range .BlockedBy}}
    <div class="row row-gap-sm">
      <a href="{{.URL}}" class="c-id-pill">{{.ShortID}}</a>
      <span class="t-body-sm">{{.Title}}</span>
      <span style="margin-left: auto">{{template "status-pill" .Status}}</span>
    </div>
    {{end}}
  </div>
</section>
{{end}}

{{if .Blocking}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Blocks</h2>
  <div class="stack stack-gap-xs">
    {{range .Blocking}}
    <div class="row row-gap-sm">
      <a href="{{.URL}}" class="c-id-pill">{{.ShortID}}</a>
      <span class="t-body-sm">{{.Title}}</span>
      <span style="margin-left: auto">{{template "status-pill" .Status}}</span>
    </div>
    {{end}}
  </div>
</section>
{{end}}

{{if .Description}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Description</h2>
  <div class="c-note">{{.Description}}</div>
</section>
{{end}}

{{if .Criteria}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Criteria</h2>
  <ul class="c-criteria stack stack-gap-xs" role="list">
    {{range .Criteria}}{{template "criterion-row" .}}{{end}}
  </ul>
</section>
{{end}}

{{if .ProgressNotes}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Progress notes</h2>
  <div class="stack stack-gap-sm">
    {{range .ProgressNotes}}{{template "progress-note-row" .}}{{end}}
  </div>
</section>
{{end}}

{{if .CompletionNote}}
<section class="c-section">
  <h2 class="c-section__label t-label-caps">Completion note</h2>
  <div class="c-note">{{.CompletionNote}}</div>
</section>
{{end}}

<section class="c-section">
  <h2 class="c-section__label t-label-caps">History</h2>
  <div class="stack stack-gap-sm">
    {{range .History}}
    <div class="c-history-entry stack stack-gap-xs" data-event-type="{{.EventType}}">
      <div class="row row-gap-sm t-body-sm">
        {{if .Actor}}
        <a href="{{.ActorURL}}" class="c-log-row__actor" data-actor="{{.Actor}}">
          <span class="c-avatar c-avatar-sm" data-actor="{{.Actor}}"></span>
        </a>
        <span class="t-body-sm">{{.Verb}} <strong>{{.Actor}}</strong>{{if .ClusterSummary}} <span class="c-history-summary t-dim">({{.ClusterSummary}})</span>{{end}}</span>
        {{else}}
        <span class="c-avatar c-avatar-sm" aria-hidden="true"></span>
        <span class="t-body-sm t-muted">{{.Verb}}{{if .ClusterSummary}} <span class="c-history-summary t-dim">({{.ClusterSummary}})</span>{{end}}</span>
        {{end}}
        <time class="t-dim t-data-id" style="margin-left: auto" datetime="{{.ISOTime}}">{{.RelTime}} ago</time>
      </div>
    </div>
    {{else}}
    <span class="t-muted t-body-sm">No events yet.</span>
    {{end}}
  </div>
</section>
{{end}}

{{- /* Inline partial: one criterion row. Renders an inline SVG icon
     for each of the four states (passed disc+check, pending outline
     circle, skipped disc+dash, failed disc+×), the label, and a quiet
     trailing state badge for screen-readers / color-blind users.
     The data-criterion-state attribute carries the raw state for CSS
     coloring (via currentColor on the icon) and tests. */ -}}
{{define "criterion-row"}}
  {{- $s := .State -}}
  <li class="c-criterion" data-criterion-state="{{$s}}">
    {{template "criterion-icon" $s}}
    <span class="c-criterion__label">{{.Label}}</span>
    {{- if .StateBadge -}}
    <span class="c-criterion__badge c-criterion__badge--{{$s}}">{{.StateBadge}}</span>
    {{- end -}}
  </li>
{{end}}

{{- /* Inline SVG glyph for one criterion state. Disc shapes carry
     fill="currentColor" so the per-state CSS rule (matched by
     data-criterion-state on the parent) controls the color. The
     pending state is an outline-only circle; the others overlay a
     mark in the surface color so it stays legible on the disc. */ -}}
{{define "criterion-icon"}}
  {{- if eq . "passed" -}}
    <svg class="c-criterion__icon c-criterion__icon--passed" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="currentColor"/><path d="M5 8.5l2 2 4-4" fill="none" stroke="#0b1113" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {{- else if eq . "skipped" -}}
    <svg class="c-criterion__icon c-criterion__icon--skipped" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="currentColor"/><path d="M4.5 8h7" stroke="#0b1113" stroke-width="1.6" stroke-linecap="round"/></svg>
  {{- else if eq . "failed" -}}
    <svg class="c-criterion__icon c-criterion__icon--failed" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="7" fill="currentColor"/><path d="M5.5 5.5l5 5M10.5 5.5l-5 5" stroke="#0b1113" stroke-width="1.6" stroke-linecap="round"/></svg>
  {{- else -}}
    <svg class="c-criterion__icon c-criterion__icon--pending" viewBox="0 0 16 16" aria-hidden="true"><circle cx="8" cy="8" r="6.25" fill="none" stroke="currentColor" stroke-width="1.5"/></svg>
  {{- end -}}
{{end}}

{{- /* Inline partial: one Progress notes row. Mirrors the History
     row's actor avatar/link, but pulls the body into its own line so
     longer notes wrap without crowding the timestamp. The History
     section will (in a sibling task) drop the inline note text now
     that this section owns the body. */ -}}
{{define "progress-note-row"}}
  <div class="c-progress-note">
    <a href="{{.ActorURL}}" class="c-log-row__actor" data-actor="{{.Actor}}">
      <span class="c-avatar c-avatar-sm" data-actor="{{.Actor}}"></span>
      <strong>{{.Actor}}</strong>
    </a>
    <time class="t-dim t-data-id" datetime="{{.ISOTime}}">{{.RelTime}} ago</time>
    <p class="c-progress-note__body">{{.Text}}</p>
  </div>
{{end}}

{{- /* Inline partial: a status pill for a given status string. */ -}}
{{define "status-pill"}}
  {{- $s := . -}}
  <span class="c-status-pill c-status-pill--{{if eq $s "active"}}active{{else if eq $s "blocked"}}blocked{{else if eq $s "done"}}done{{else if eq $s "canceled"}}done{{else}}todo{{end}}">
    {{- if eq $s "done" -}}
      <svg class="c-status-pill__icon" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M2 5l2 2 4-4" stroke-linecap="round" stroke-linejoin="round" /></svg>Done
    {{- else if eq $s "active" -}}
      <svg class="c-status-pill__icon" viewBox="0 0 10 10" fill="currentColor" aria-hidden="true"><circle cx="5" cy="5" r="3" /></svg>Active
    {{- else if eq $s "blocked" -}}
      <svg class="c-status-pill__icon" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="2.5" width="1.5" height="5" /><rect x="5.5" y="2.5" width="1.5" height="5" /></svg>Blocked
    {{- else if eq $s "canceled" -}}
      Canceled
    {{- else -}}
      Todo
    {{- end -}}
  </span>
{{end}}
