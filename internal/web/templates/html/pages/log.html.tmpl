{{- /* Log view. Markup ports prototype/log.html with data bindings.
     No live tail yet — this is the SSR initial render only (task dARuR). */ -}}
{{define "title"}}Log · Jobs{{end}}
{{define "live-region-src"}}{{.EventsURL}}{{end}}
{{define "content"}}
<section class="c-filter-bar" aria-label="Log filters">
  <div class="c-filter-bar__group" role="group" aria-label="Event type">
    <span class="c-filter-bar__label">Events</span>
    {{range .EventTypes}}
    <a href="{{.HRef}}" class="c-filter-chip{{if .Active}} c-filter-chip--active{{end}}">{{.Label}}</a>
    {{end}}
  </div>
  <div class="c-filter-bar__group" role="group" aria-label="Actor">
    <span class="c-filter-bar__label">Actor</span>
    {{range .Actors}}
    <a href="{{.HRef}}" class="c-filter-chip{{if .Active}} c-filter-chip--active{{end}}">
      {{if .Actor}}<span class="c-avatar c-avatar-dot" data-actor="{{.Actor}}"></span>{{end}}{{.Label}}
    </a>
    {{end}}
  </div>
  <div class="c-filter-bar__group" role="group" aria-label="Label">
    <span class="c-filter-bar__label">Label</span>
    {{range .Labels}}
    {{- if .LabelK -}}
    <a href="{{.HRef}}" class="c-label-pill{{if .Active}} c-label-pill--active{{end}}" data-label="{{.LabelK}}">{{.Label}}</a>
    {{- else -}}
    <a href="{{.HRef}}" class="c-filter-chip{{if .Active}} c-filter-chip--active{{end}}">{{.Label}}</a>
    {{- end -}}
    {{end}}
  </div>
</section>

<div class="c-log-live" aria-live="polite">
  <span class="c-log-live__dot"></span>
  <span>SSR snapshot · newest first</span>
  <span class="grow"></span>
  <span class="t-dim">showing {{.TotalShown}} of {{.TotalEvents}} events</span>
</div>

<div class="c-log" role="list">
  {{range .Events}}
  <div class="c-log-row c-log-row--{{.EventType}}" role="listitem" data-event-id="{{.EventID}}">
    <time class="c-log-row__time" datetime="{{.ISOTime}}">{{.RelTime}}</time>
    <a href="{{.ActorURL}}" class="c-log-row__actor" data-actor="{{.Actor}}">
      <span class="c-avatar c-avatar-sm" data-actor="{{.Actor}}"></span>
      <span>{{.Actor}}</span>
    </a>
    <span class="c-log-row__verb c-log-row__verb--{{.EventType}}">{{.EventType}}</span>
    <span class="c-id-pill">{{.ShortID}}</span>
    <span class="c-log-row__detail">
      {{if .Title}}<span class="c-log-row__title">{{.Title}}</span>{{end}}
      {{if .Note}}<span class="c-log-row__note">{{.Note}}</span>{{end}}
    </span>
    <a href="{{.TaskURL}}" class="c-row-link" aria-label="Open task {{.ShortID}}"></a>
  </div>
  {{else}}
  <div class="c-log-row c-log-row--empty" role="listitem">
    <span class="t-muted">No events match the current filters.</span>
  </div>
  {{end}}
</div>
{{end}}
