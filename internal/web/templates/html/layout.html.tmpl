{{- /* Base layout. Markup ports the prototype's .page scaffold
     (prototype/home.html et al.) with hrefs rewritten from *.html to
     real routes, and the three prototype stylesheets linked in order. */ -}}
{{define "layout"}}<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{block "title" .}}Jobs{{end}}</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2032%2032%22%3E%3Ccircle%20cx%3D%2216%22%20cy%3D%2216%22%20r%3D%2213%22%20fill%3D%22%235a6967%22%2F%3E%3C%2Fsvg%3E">
<link rel="stylesheet" href="{{asset "css/tokens.css"}}">
<link rel="stylesheet" href="{{asset "css/base.css"}}">
<link rel="stylesheet" href="{{asset "css/components.css"}}">
</head>
<body>
<a href="#main" class="c-skip-link">Skip to main content</a>
<div class="page">
{{template "header" .}}
<div class="c-history-banner" role="status" aria-live="polite" data-history-banner hidden>
  <span class="c-history-banner__dot"></span>
  <span>Viewing history</span>
  <span class="c-history-banner__at" data-history-banner-at>—</span>
  <span class="grow"></span>
  <button type="button" class="c-history-banner__return" data-scrubber-return>
    <span class="c-history-banner__return-dot"></span>
    Return to live
  </button>
</div>
<main id="main" class="main" role="main" tabindex="-1">{{block "content" .}}{{end}}</main>
{{template "footer" .}}
</div>
<live-region src="{{block "live-region-src" .}}/events{{end}}"></live-region>
<peek-sheet></peek-sheet>
{{- if .InitialFrameJSON}}
<script type="application/json" id="initial-frame">{{.InitialFrameJSON}}</script>
{{- end}}
<script src="{{asset "js/colors.js"}}"></script>
<script src="{{asset "js/chrome.js"}}"></script>
<script src="{{asset "js/live.js"}}"></script>
<script src="{{asset "js/log-live.js"}}"></script>
<script src="{{asset "js/home-live.js"}}"></script>
<script src="{{asset "js/actors-live.js"}}"></script>
<script src="{{asset "js/peek-sheet.js"}}"></script>
<script src="{{asset "js/peek-click.js"}}"></script>
<script src="{{asset "js/peek-bell.js"}}"></script>
<script src="{{asset "js/plan-collapse.js"}}"></script>
<script src="{{asset "js/plan-live.js"}}"></script>
<script src="{{asset "js/plan-keyboard.js"}}"></script>
<script type="importmap">
{
  "imports": {
    "/static/js/replay.mjs": "{{asset "js/replay.mjs"}}",
    "/static/js/scrubber-cursor.mjs": "{{asset "js/scrubber-cursor.mjs"}}",
    "/static/js/scrub-util.mjs": "{{asset "js/scrub-util.mjs"}}",
    "/static/js/plan-scrub-build.mjs": "{{asset "js/plan-scrub-build.mjs"}}",
    "/static/js/plan-scrub-render.mjs": "{{asset "js/plan-scrub-render.mjs"}}",
    "/static/js/actors-scrub-build.mjs": "{{asset "js/actors-scrub-build.mjs"}}",
    "/static/js/actors-scrub-render.mjs": "{{asset "js/actors-scrub-render.mjs"}}",
    "/static/js/home-scrub-build.mjs": "{{asset "js/home-scrub-build.mjs"}}",
    "/static/js/home-scrub-render.mjs": "{{asset "js/home-scrub-render.mjs"}}"
  }
}
</script>
<script type="module" src="{{asset "js/search.mjs"}}"></script>
<script type="module" src="{{asset "js/shortcuts.mjs"}}"></script>
<script type="module" src="{{asset "js/favicon.mjs"}}"></script>
<script type="module" src="{{asset "js/scrubber-bootstrap.mjs"}}"></script>
<script type="module" src="{{asset "js/scrubber-pill.mjs"}}"></script>
<script type="module" src="{{asset "js/plan-scrub.mjs"}}"></script>
<script type="module" src="{{asset "js/actors-scrub.mjs"}}"></script>
<script type="module" src="{{asset "js/log-scrub.mjs"}}"></script>
<script type="module" src="{{asset "js/home-scrub.mjs"}}"></script>
</body>
</html>
{{end}}
