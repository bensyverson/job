{{- /* Base layout. Markup ports the prototype's .page scaffold
     (prototype/home.html et al.) with hrefs rewritten from *.html to
     real routes, and the three prototype stylesheets linked in order. */ -}}
{{define "layout"}}<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{block "title" .}}Jobs{{end}}</title>
<link rel="stylesheet" href="{{asset "css/tokens.css"}}">
<link rel="stylesheet" href="{{asset "css/base.css"}}">
<link rel="stylesheet" href="{{asset "css/components.css"}}">
</head>
<body>
<div class="page">
{{template "header" .}}
<main class="main" role="main">{{block "content" .}}{{end}}</main>
{{template "footer" .}}
</div>
<live-region src="{{block "live-region-src" .}}/events{{end}}"></live-region>
<peek-sheet></peek-sheet>
{{- if .InitialFrameJSON}}
<script type="application/json" id="initial-frame">{{.InitialFrameJSON}}</script>
{{- end}}
<script src="{{asset "js/colors.js"}}"></script>
<script src="{{asset "js/chrome.js"}}"></script>
<script src="{{asset "js/live.js"}}"></script>
<script src="{{asset "js/log-live.js"}}"></script>
<script src="{{asset "js/home-live.js"}}"></script>
<script src="{{asset "js/actors-live.js"}}"></script>
<script src="{{asset "js/peek-sheet.js"}}"></script>
<script src="{{asset "js/peek-click.js"}}"></script>
<script src="{{asset "js/peek-bell.js"}}"></script>
<script src="{{asset "js/plan-collapse.js"}}"></script>
<script src="{{asset "js/plan-live.js"}}"></script>
<script src="{{asset "js/plan-keyboard.js"}}"></script>
<script type="module" src="{{asset "js/scrubber-bootstrap.mjs"}}"></script>
</body>
</html>
{{end}}
